# ============================================================
# Dockerfile — образ с Aider агентом
#
# Собирается один раз: docker compose build
# Проект монтируется снаружи как volume —
# образ не содержит исходников, только инструмент.
# ============================================================

FROM python:3.12-slim

# Git  — нужен Aider для коммитов и работы с репозиторием
# curl — для диагностики сети внутри контейнера
#        например: curl http://llama:8080/health
RUN apt-get update && apt-get install -y \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Aider — основной инструмент агента
# --break-system-packages не нужен — в контейнере нет системного Python
RUN pip install aider-chat

# Создаём пользователя с тем же UID/GID что и на хосте —
# иначе файлы созданные внутри контейнера будут принадлежать root
# и git/rollback команды на хосте будут падать с "Отказано в доступе"
# UID=1000 — стандартный UID первого пользователя на Linux
ARG UID=1000
ARG GID=1000
RUN groupadd -g $GID aider && useradd -u $UID -g $GID -m aider

# Разрешаем git работать с примонтированной директорией
# По умолчанию git блокирует директории чужого владельца
# (владелец на хосте и в контейнере могут отличаться)
RUN git config --global --add safe.directory /project

# Переключаемся на непривилегированного пользователя —
# все последующие команды и ENTRYPOINT выполняются от его имени
# Файлы созданные aider будут принадлежать этому пользователю
USER aider

# Рабочая директория = примонтированный проект с хоста
WORKDIR /project

# Все аргументы из sh файлов передаются напрямую в aider
ENTRYPOINT ["aider"]