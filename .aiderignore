# ============================================================
# .aiderignore — файлы которые агент не читает и не меняет
#
# Зачем нужен:
#   - Агент строит repo map из ВСЕХ файлов проекта
#   - Каждый лишний файл тратит токены контекстного окна
#   - Бинарники и генерируемые файлы не несут смысла для LLM
#
# Правило: чем меньше файлов видит агент —
#   тем точнее repo map и дешевле каждый запрос
# ============================================================

# --- Сборка ---
# Генерируется автоматически — агенту незачем эти файлы читать или менять
target/
build/
out/

# --- Зависимости ---
# Тысячи файлов которые агент не должен трогать
node_modules/
.gradle/
.mvn/

# --- Lock файлы ---
# Огромные автогенерируемые файлы — съедают токены впустую
package-lock.json
yarn.lock
poetry.lock

# --- Логи агента ---
# Агент не должен читать свои же предыдущие логи —
# это создаёт путаницу в контексте
llm_history/

# --- Конфиги с секретами ---
# Агенту незачем видеть ключи API
aider-agent/env.local
aider-agent/env.openrouter

# --- Скрипты агента ---
aider-agent/
.aider.model.metadata.json
.aider.model.settings.yml
.gitignore
.aiderignore

# --- IDE ---
.idea/
*.iml
README.md

# --- Бинарники ---
# LLM не умеет работать с бинарными файлами
*.class
*.jar
*.war

# --- Медиа ---
# Изображения и документы не несут смысла для кодирования
*.png
*.jpg
*.gif
*.svg
*.ico
*.pdf
*.zip

# --- Базы данных ---
*.db
*.sqlite

# --- Кэш aider ---
# Служебные файлы самого aider
.aider.tags.cache.v4/
.aider.chat.history.md